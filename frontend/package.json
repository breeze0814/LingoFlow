{
  "name": "lingoflow-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run sync:tesseract-assets && vite",
    "dev:tauri": "npm run sync:tesseract-assets && node ./scripts/run-tauri-dev-server.mjs",
    "build": "npm run sync:tesseract-assets && tsc -b && vite build",
    "postinstall": "npm run sync:tesseract-assets",
    "sync:tesseract-assets": "node ./scripts/sync-tesseract-assets.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,html}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tesseract.js-data/chi_sim": "^1.0.0",
    "@tesseract.js-data/deu": "^1.0.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/fra": "^1.0.0",
    "@tesseract.js-data/jpn": "^1.0.0",
    "@tesseract.js-data/kor": "^1.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
