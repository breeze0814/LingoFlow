{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LingoFlow",
  "version": "0.1.0",
  "identifier": "com.lingoflow",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev:tauri",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "LingoFlow",
        "width": 900,
        "height": 620,
        "resizable": true,
        "visible": false
      },
      {
        "label": "ocr_result",
        "title": "OCR 结果",
        "url": "?window=ocr_result",
        "width": 410,
        "height": 720,
        "resizable": true,
        "visible": false,
        "transparent": true,
        "alwaysOnTop": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      },
      {
        "label": "ocr_runtime",
        "title": "OCR Runtime",
        "url": "?window=ocr_runtime",
        "width": 64,
        "height": 64,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "screenshot_overlay",
        "title": "Screenshot Overlay",
        "url": "?window=screenshot_overlay",
        "width": 64,
        "height": 64,
        "resizable": false,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  }
}
